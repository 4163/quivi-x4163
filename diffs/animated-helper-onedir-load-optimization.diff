    def _get_webp_helper_command(cls, helper_onedir_exe, helper_exe,
                                 helper_script):
        if os.path.isfile(helper_onedir_exe):
            return [helper_onedir_exe]
        if os.path.isfile(helper_exe):
            return [helper_exe]
        if os.path.isfile(helper_script):
            return [cls._get_webp_helper_python(), helper_script]

