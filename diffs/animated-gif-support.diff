+class AnimatedImage(object):
+
+    @classmethod
+    def load(cls, path, flags=0):
+        lib = library.load()
+        fif = lib.GetFIFFromFilename(path)
+        multi = None
+        frames = []
+        delays = []
+        try:
+            if fif == CO.FIF_UNKNOWN or not lib.FIFSupportsReading(fif):
+                raise RuntimeError('Unable to open animated image')
+            multi = lib.OpenMultiBitmap(fif, path, False, True, True, flags)
+            if not multi:
+                raise RuntimeError('Unable to open animated image')
+            count = lib.GetPageCount(multi)
+            if count <= 1:
+                raise RuntimeError('Image is not animated')
+            for idx in xrange(count):
+                page = lib.LockPage(multi, idx)
+                if not page:
+                    continue
+                try:
+                    delays.append(cls._get_frame_delay(lib, page))
+                    dib = lib.Clone(page)
+                    if not dib:
+                        raise RuntimeError('Unable to clone animation frame')
+                    frames.append(Image(dib))
+                finally:
+                    lib.UnlockPage(multi, page, False)
+        finally:
+            if multi:
+                lib.CloseMultiBitmap(multi, 0)
+        if not frames:
+            raise RuntimeError('Unable to load animation frames')
+        return cls(frames, delays)
+
+    @staticmethod
+    def _get_frame_delay(lib, dib):
+        tag = ctypes.c_void_p()
+        delay = 100
+        try:
+            ok = lib.GetMetadata(CO.FIMD_ANIMATION, dib, 'FrameTime', ctypes.byref(tag))
+            if ok and tag:
+                value = lib.GetTagValue(tag)
+                if value:
+                    delay = ctypes.cast(value, ctypes.POINTER(ctypes.c_uint)).contents.value
+        except Exception:
+            pass
+        if delay < 20:
+            delay = 100
+        return delay
+
+    def __init__(self, frames, delays):
+        self.frames = frames
+        self.delays = delays
+        self.index = 0
+        self.is_animated = True
+        return
+
+    @property
+    def current(self):
+        return self.frames[self.index]
+
+    @property
+    def frame_delay(self):
+        return self.delays[self.index]
+
+    def advance_frame(self):
+        self.index = (self.index + 1) % len(self.frames)
+        return self.frame_delay
+
+    def composite(self, use_file_bg=False, app_bg_color=None, bg=None):
+        frames = [frame.composite(use_file_bg, app_bg_color, bg) for frame in self.frames]
+        return self.__class__(frames, self.delays[:])
+
+    def convert_to_24_bits(self):
+        frames = [frame.convert_to_24_bits() for frame in self.frames]
+        return self.__class__(frames, self.delays[:])
+
+    def convert_to_32_bits(self):
+        frames = [frame.convert_to_32_bits() for frame in self.frames]
+        return self.__class__(frames, self.delays[:])
+
+    def rescale(self, width, height, resampling_filter):
+        frames = [frame.rescale(width, height, resampling_filter) for frame in self.frames]
+        img = self.__class__(frames, self.delays[:])
+        img.index = self.index
+        return img
+
+    def rotate(self, angle):
+        frames = [frame.rotate(angle) for frame in self.frames]
+        img = self.__class__(frames, self.delays[:])
+        img.index = self.index
+        return img
+
+    def __getattr__(self, name):
+        return getattr(self.current, name)

